# MongoDB Connection URI (100% MongoDB)
MONGODB_URI="mongodb://localhost:27017/subtitle_bot"

# Telegram Bot Token
BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Gemini API Key
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Telegram Client Account API Credentials
TELEGRAM_API_ID="YOUR_TELEGRAM_API_ID"
TELEGRAM_API_HASH="YOUR_TELEGRAM_API_HASH"

# Web App Port & Public URL
PORT=3000
APP_URL="YOUR_APP_PUBLIC_URL"

# Optional: Proxy for Translation API (to bypass Cloudflare blocks on VPS like Contabo)
# Format: http://username:password@ip:port or http://ip:port
# TRANSLATOR_PROXY="http://your-proxy-address:port"
